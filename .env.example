# Backend API URL
# Uncomment dan sesuaikan dengan environment Anda

# Untuk local development
# VITE_BACKEND_URL=http://localhost:3000

# Untuk IP lokal (surya)
# VITE_BACKEND_URL=http://192.168.100.103:3000

# Untuk IP ITB
# VITE_BACKEND_URL=http://10.251.108.83:3000

# Untuk devtunnels (ganti dengan URL backend devtunnels Anda)
# Frontend: https://jstlmtmc-5173.asse.devtunnels.ms/
# Backend: https://jstlmtmc-3000.asse.devtunnels.ms
VITE_BACKEND_URL=https://jstlmtmc-3000.asse.devtunnels.ms

# Untuk forward port / production lainnya
# VITE_BACKEND_URL=http://your-domain.com:3000

# AI API Keys (Optional - untuk chatbot widget)
# Dapatkan API keys dari:
# DeepSeek: https://platform.deepseek.com/
# Groq: https://console.groq.com/
# Gemini: https://makersuite.google.com/app/apikey
# OpenRouter: https://openrouter.ai/keys
# Cohere: https://dashboard.cohere.com/api-keys
# HuggingFace: https://huggingface.co/settings/tokens
# DeepInfra: https://deepinfra.com/dash/api_keys

VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_COHERE_API_KEY=your_cohere_api_key_here
VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key_here
VITE_DEEPINFRA_API_KEY=your_deepinfra_api_key_here
